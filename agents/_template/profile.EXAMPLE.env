# ============================================
# AGENT PROFILE,  Configuration Template
# ============================================
# Copy this folder to create a new agent profile.
# All values here override the root .env when running
# with --profile <name>
# ============================================

# ============================================
# INTERFACE MODE
# ============================================
CLI_ENABLED=false
PIXEL_BRIDGE_ENABLED=true

# ============================================
# CORE LLM SETTINGS
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=llama3.1:8b
AUTO_SELECT_MODEL=true

# API Keys for external LLM providers (optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# EXTERNAL API KEYS (Tools)
# ============================================
OPENWEATHER_API_KEY=

# ============================================
# TELEGRAM BOT (Primary Interface)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# Telegram Userbot (Advanced - for monitoring groups/channels)
TELEGRAM_USERBOT_ENABLED=false
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE_NUMBER=
TELEGRAM_SESSION_NAME=opensable_session
USERBOT_AUTO_RESPOND=true

# ============================================
# OTHER CHAT PLATFORMS
# ============================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
WHATSAPP_ENABLED=true

# IRC Configuration
IRC_SERVER=irc.libera.chat
IRC_PORT=6667
IRC_NICKNAME=opensable_bot
IRC_CHANNELS=#opensable,#ai

# Matrix Configuration
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER=@opensable:matrix.org
MATRIX_PASSWORD=

# Slack Configuration
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ============================================
# EMAIL & CALENDAR INTEGRATION
# ============================================
GMAIL_ENABLED=true
GMAIL_CREDENTIALS_PATH=./config/gmail_credentials.json
CALENDAR_ENABLED=true
CALENDAR_CREDENTIALS_PATH=./config/calendar_credentials.json

# ============================================
# SECURITY & SANDBOX
# ============================================
ENABLE_SANDBOX=true
ALLOWED_DOMAINS=*.google.com,*.booking.com,*.airbnb.com
MAX_FILE_SIZE_MB=100

# ============================================
# AGENT BEHAVIOR
# ============================================
AGENT_NAME=Sable
AGENT_PERSONALITY=sarcastic
HEARTBEAT_INTERVAL=300
MAX_RETRIES=3

# ============================================
# AUTONOMOUS MODE
# ============================================
AUTONOMOUS_MODE=true
AUTONOMOUS_ENABLED=false
AUTONOMOUS_CHECK_INTERVAL=60
AUTONOMOUS_MAX_TASKS=3
AUTONOMOUS_SOURCES=calendar,email,scheduled_tasks

# ============================================
# MEMORY & STORAGE
# ============================================
MEMORY_RETENTION_DAYS=90
VECTOR_DB_PATH=./data/vectordb
DATA_DIR=./data

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=./logs/opensable.log

# ============================================
# VOICE INTERFACE (Experimental)
# ============================================
VOICE_ENABLED=false
VOICE_STT_MODEL=base
VOICE_TTS_VOICE=en-us-blizzard_lessac-medium
VOICE_INPUT_DEVICE=default
VOICE_OUTPUT_DEVICE=default
VOICE_DEVICE=cpu

# ============================================
# MULTIMODAL (Vision & Audio Processing)
# ============================================
VISION_ENABLED=false
VISION_MODEL=yolov8n
VISION_CACHE_SIZE=1000
VISION_DEVICE=cpu
VISION_CACHE_DIR=./models/vision
AUDIO_CACHE_SIZE=500
AUDIO_CACHE_DIR=./models/audio
OCR_ENABLED=false

# ============================================
# AGENTIC AI CORE SUBSYSTEMS
# ============================================
AGI_STORAGE_DIR=./data/agi
AGI_MEMORY_CONSOLIDATION_INTERVAL=1
AGI_META_LEARNING_INTERVAL=24
AGI_MAX_EPISODIC_MEMORIES=10000
AGI_MAX_SEMANTIC_MEMORIES=50000
AGI_WORKING_MEMORY_CAPACITY=7
AGI_TOOL_SYNTHESIS_ENABLED=true
AGI_TOOL_SAFETY_STRICT=true

# ============================================
# MULTI-DEVICE SYNC
# ============================================
SYNC_ENABLED=false
SYNC_SERVER_URL=ws://localhost:8080
SYNC_ENCRYPTION_KEY=
SYNC_ENABLE_ENCRYPTION=false
SYNC_CONFLICT_STRATEGY=latest_wins
SYNC_INTERVAL=30

# ============================================
# GOAL SYSTEM & META-LEARNING
# ============================================
GOAL_STORAGE_PATH=./data/goals
GOAL_MAX_DEPTH=5
GOAL_DECOMPOSE_ENABLED=true
META_LEARNING_ENABLED=false

# ============================================
# TOOL SYNTHESIS (Dynamic Tool Creation)
# ============================================
TOOL_SYNTHESIS_ENABLED=false
TOOL_STORAGE_PATH=./data/synthesized_tools
TOOL_MAX_COMPLEXITY=medium

# ============================================
# SKILLS MARKETPLACE
# ============================================
SKILLS_REGISTRY_URL=https://sk.opensable.com
SKILLS_API_URL=https://sk.opensable.com/api
SKILLS_STORE_URL=https://skills.opensable.com
SKILLS_AUTO_UPDATE=true
SKILLS_VERIFY_SIGNATURES=true
SKILLS_DIR=./skills
SABLE_GATEWAY_URL=https://sk.opensable.com/gateway
SABLE_AGENT_ID=
SABLE_AGENT_SIGNING_KEY=
SABLE_AGENT_ENCRYPTION_KEY=
SABLE_STORE_API_KEY=

# ============================================
# DATABASE CONNECTIONS
# ============================================
DATABASE_TYPE=sqlite
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opensable
POSTGRES_USER=
POSTGRES_PASSWORD=
MONGODB_URI=
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
METRICS_EXPORT_INTERVAL=60

# ============================================
# ENTERPRISE FEATURES
# ============================================
MULTI_TENANT_ENABLED=false
RBAC_ENABLED=false
AUDIT_LOG_ENABLED=false
WEBHOOK_ENABLED=false
WEBHOOK_URL=

# ============================================
# BROWSER AUTOMATION
# ============================================
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30
BROWSER_MAX_TABS=5

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ============================================
# MOBILE API & RELAY
# ============================================
MOBILE_API_ENABLED=true
MOBILE_API_PORT=8000
MOBILE_RELAY_ENABLED=true
MOBILE_RELAY_HOST=0.0.0.0
MOBILE_RELAY_PORT=4810
MOBILE_RELAY_URL=wss://0.0.0.0:4810/mobile/ws
MOBILE_JWT_SECRET=
MOBILE_ALLOWED_ORIGINS=https://opensable.com,https://skills.opensable.com

# ============================================
# ANALYTICS & TELEMETRY
# ============================================
ANALYTICS_ENABLED=false
TELEMETRY_ENABLED=false
USAGE_STATS_ENABLED=false

# ============================================
# ADVANCED
# ============================================
DEBUG_MODE=false
ENABLE_EXPERIMENTAL_FEATURES=false
MAX_CONTEXT_LENGTH=8192
CACHE_TTL=3600
WORKER_THREADS=4
MAX_CONCURRENT_REQUESTS=100

# ============================================
# PLUGIN SYSTEM
# ============================================
PLUGINS_ENABLED=false
PLUGINS_DIR=./plugins
PLUGINS_AUTO_LOAD=false

# ============================================
# NOTIFICATIONS
# ============================================
NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ============================================
# WEBCHAT & GATEWAY
# ============================================
GATEWAY_ENABLED=true
WEBCHAT_HOST=0.0.0.0
WEBCHAT_PORT=8789
WEBCHAT_TOKEN=

# Desktop Agent (Electron)
DESKTOP_ENABLED=true
OPENSABLE_API_URL=ws://127.0.0.1:8789

# ============================================
# X/TWITTER AUTONOMOUS AGENT
# ============================================
X_ENABLED=true
X_USERNAME=
X_EMAIL=
X_PASSWORD=
X_AUTOPOSTER_ENABLED=true
GROK_ENABLED=true

# Content settings
X_TOPICS=geopolitics,tech,ai,crypto,cybersecurity,politics,war,economics,finance,startups,science,space,climate,energy,nuclear,military,intelligence,privacy,surveillance,hacking,drones,robotics,biotech,medicine,pandemics,china,russia,usa,europe,middle-east,africa,latin-america,elections,democracy,authoritarianism,propaganda,disinfo,media,journalism,censorship,free-speech,social-media,culture-war,philosophy,existentialism,consciousness,psychology,human-nature,history,collapse,civilization,inequality,housing,immigration,education,labor,unions,corporate-greed,billionaires,corruption,justice,law,supreme-court,nato,un,sanctions,trade-war,supply-chain,food-security,water,infrastructure,internet,open-source,linux,programming,web3,nft,defi,gaming,movies,music,books,memes,viral,breaking-news
X_STYLE=analyst
X_LANGUAGE=en

# Posting limits
X_POST_INTERVAL=3600
X_ENGAGE_INTERVAL=600
X_MAX_DAILY_POSTS=12
X_MAX_DAILY_ENGAGEMENTS=40

# Behavior probabilities (0.0 to 1.0)
X_REPLY_PROBABILITY=0.15
X_LIKE_PROBABILITY=0.35
X_RETWEET_PROBABILITY=0.10
X_FOLLOW_PROBABILITY=0.05
X_QUOTE_PROBABILITY=0.05
X_BOOKMARK_PROBABILITY=0.10

# Accounts to watch and engage with
X_ACCOUNTS_TO_WATCH=
X_CUSTOM_FEEDS=

# X Auth Cookies
X_AUTH_TOKEN=
X_CT0=
X_KDT=
X_TWID=

X_DRY_RUN=false
X_ACTION_DELAY=8

# ============================================
# INSTAGRAM
# ============================================
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ============================================
# FACEBOOK
# ============================================
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ============================================
# LINKEDIN
# ============================================
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=

# ============================================
# TIKTOK
# ============================================
TIKTOK_MS_TOKEN=
TIKTOK_BROWSER=chromium

# ============================================
# YOUTUBE
# ============================================
YOUTUBE_API_KEY=
YOUTUBE_ACCESS_TOKEN=
